# ============================================================
# EduAsset CMS — 环境变量配置模板
#
# 使用方法：
#   cp .env.example .env
#   然后填写下方各项配置
#
# ⚠️  .env 文件已在 .gitignore 中忽略，不会被提交到 Git
# ⚠️  请勿将真实密钥提交到代码仓库
# ============================================================

# ── 服务端口 ────────────────────────────────────────────────
# CMS 前端对外暴露的宿主机端口（默认 8080）
CMS_PORT=8080

# 上传服务内部端口（通常不需要修改）
UPLOAD_PORT=8788

# ── Overleaf 备份系统配置 ────────────────────────────────────
# Overleaf 实例地址（Docker 内访问宿主机用 host.docker.internal）
OVERLEAF_BASE_URL=http://host.docker.internal:80

# Overleaf 管理员账号
OVERLEAF_ADMIN_EMAIL=admin@example.com
OVERLEAF_ADMIN_PASSWORD=your_admin_password

# 备份文件存储路径（宿主机绝对路径）
HOST_BACKUP_PATH=/Users/your_username/overleaf-backups

# Overleaf 备份后端 API Token（由备份后端生成，用于前端鉴权）
# 访问 http://localhost:8080/cms/?token=YOUR_TOKEN 可自动写入浏览器
OVERLEAF_ACCESS_TOKEN=

# ── MinerU API 配置 ──────────────────────────────────────────
# 从 https://mineru.net 获取 API Key
# 也可在系统设置页面配置，会自动持久化到浏览器 localStorage
MINERU_API_KEY=

# ── AI 识别配置（Kimi/Moonshot）──────────────────────────────
# 从 https://platform.moonshot.cn 获取 API Key
# 也可在系统设置页面配置，会自动持久化到浏览器 localStorage
KIMI_API_KEY=

# ── 时区 ────────────────────────────────────────────────────
TZ=Asia/Shanghai
