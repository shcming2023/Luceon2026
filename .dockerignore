# ============================================================
# EduAsset CMS — Docker 构建忽略文件
#
# 排除不需要复制到 Docker 构建上下文的文件，
# 减少构建上下文体积，加快构建速度
# ============================================================

# 依赖目录（构建时会重新安装）
node_modules/
.pnpm-store/

# 构建产物（构建时会重新生成）
dist/
build/

# 环境变量文件（含敏感信息，不应进入镜像）
.env
.env.local
.env.*.local

# Git 相关
.git/
.gitignore

# 编辑器配置
.vscode/
.idea/
.codebuddy/

# 测试文件（含测试 PDF，体积较大）
test/

# UAT 报告（仅文档，不需要进入镜像）
UATReport/

# E2E 测试（Playwright 测试脚本，非生产）
e2e/
playwright.config.ts

# 开发文档（不需要进入镜像）
docs/
guidelines/
*.md
!README.md

# 日志文件
*.log
npm-debug.log*
pnpm-debug.log*

# 系统文件
.DS_Store
Thumbs.db

# TypeScript 增量编译缓存
*.tsbuildinfo

# Vite 缓存
.vite/

# proxy-server 仅供局域网直连运行，不打包进 Docker 镜像
server/proxy-server.mjs
